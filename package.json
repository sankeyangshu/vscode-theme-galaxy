{
  "publisher": "sankeyangshu",
  "name": "galaxy-monokai-theme",
  "displayName": "Galaxy Monokai Theme",
  "version": "0.2.2",
  "packageManager": "pnpm@10.32.1",
  "description": "Galaxy Monokai Theme for VS Code",
  "author": {
    "name": "sankeyangshu",
    "email": "sankeyangshu@gmail.com",
    "url": "https://github.com/sankeyangshu"
  },
  "license": "MIT",
  "homepage": "https://github.com/sankeyangshu/vscode-theme-galaxy#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sankeyangshu/vscode-theme-galaxy"
  },
  "bugs": {
    "url": "https://github.com/sankeyangshu/vscode-theme-galaxy/issues"
  },
  "keywords": [
    "theme",
    "dark"
  ],
  "categories": [
    "Themes"
  ],
  "icon": "res/icon.png",
  "files": [
    "res/*",
    "themes/*"
  ],
  "engines": {
    "vscode": "^1.43.0"
  },
  "contributes": {
    "themes": [
      {
        "label": "Galaxy Theme",
        "uiTheme": "vs-dark",
        "path": "./themes/galaxy-dark-color-theme.json"
      }
    ]
  },
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "ext:package": "vsce package --no-dependencies",
    "ext:publish": "vsxpub --no-dependencies",
    "release": "bumpp",
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/vscode": "^1.43.0",
    "@vscode/vsce": "^3.7.1",
    "bumpp": "^11.0.1",
    "eslint": "^10.0.3",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "vsxpub": "^0.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
